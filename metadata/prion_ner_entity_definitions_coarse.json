  "entity_types": [
    {
      "coarse_type": "Generic_Prion",
      "definition": "Mentions of prion disease when no more specific subtype is stated.",
      "examples": [
        "Creutzfeldt-Jakob disease",
        "CJD",
        "prion disease",
        "bovine spongiform encephalopathy",
        "BSE",
        "TSE"
      ]
    },
    {
      "coarse_type": "Sporadic_Prion",
      "definition": "Mentions of sporadic prion disease subtypes or explicitly sporadic forms of prion disease.",
      "examples": [
        "sporadic CJD",
        "sCJD",
        "sporadic Creutzfeldt-Jakob disease",
        "sporadic fatal insomnia",
        "sFI",
        "VPSPr"
      ]
    },
    {
      "coarse_type": "Familial_Prion",
      "definition": "Mentions of inherited or familial prion disease subtypes.",
      "examples": [
        "Fatal Familial Insomnia",
        "FFI",
